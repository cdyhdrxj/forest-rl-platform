{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Метрики эксперимента",
  "version": "1.0.0",
  "type": "object",
  "required": ["run_id", "series"],
  "properties": {
    "run_id": {
      "type": "integer"
    },
    "series": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "points"],
        "properties": {
          "name": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "aggregation": {
            "type": "string",
            "enum": ["mean", "sum", "min", "max"]
          },
          "source": {
            "type": "string",
            "enum": ["trainer", "simulator", "robot_adapter"]
          },
          "mode": {
            "type": "string",
            "enum": ["trail", "robot", "patrol", "fast", "multiagent"]
          },
          "description": {
            "type": "string"
          },
          "points": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["value", "point_index"],
              "properties": {
                "point_index": {
                  "type": "integer"
                },
                "train_step": {
                  "type": "integer"
                },
                "episode_index": {
                  "type": "integer"
                },
                "wall_time_sec": {
                  "type": "number"
                },
                "value": {
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  }
}