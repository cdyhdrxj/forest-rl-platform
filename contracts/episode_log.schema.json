{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Журнал эпизода",
  "type": "object",

  "required": [
    "run_id",
    "episode_index",
    "steps"
  ],

  "properties": {

    "run_id": {
      "type": "integer"
    },

    "episode_index": {
      "type": "integer"
    },

    "seed": {
      "type": "integer"
    },

    "steps": {
      "type": "array",

      "items": {
        "type": "object",

        "required": [
          "step_index",
          "sim_time",
          "action",
          "reward",
          "done"
        ],

        "properties": {

          "step_index": {
            "type": "integer"
          },

          "sim_time": {
            "type": "number"
          },

          "observation": {
            "type": "object",
            "description": "Сырые данные наблюдений агента"
          },

          "action": {
            "oneOf": [
              { "type": "integer" },
              {
                "type": "array",
                "items": { "type": "number" }
              }
            ]
          },

          "reward": {
            "type": "number"
          },

          "done": {
            "type": "boolean"
          },

          "agent_state": {
            "type": "object",
            "properties": {

              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" },

              "yaw": { "type": "number" },

              "vx": { "type": "number" },
              "vy": { "type": "number" },
              "omega": { "type": "number" }
            }
          },

          "events": {
            "type": "array",

            "items": {
              "type": "object",

              "required": ["type"],

              "properties": {

                "type": {
                  "type": "string",
                  "enum": [
                    "collision",
                    "goal_reached",
                    "intruder_spawn",
                    "intruder_detected",
                    "intruder_intercepted",
                    "damage",
                    "timeout"
                  ]
                },

                "value": {
                  "type": "number"
                },

                "position": {
                  "type": "array",
                  "items": { "type": "number" }
                }
              }
            }
          }
        }
      }
    }
  }
}