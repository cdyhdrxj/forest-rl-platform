{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Метрики эксперимента",
  "type": "object",

  "required": ["run_id", "metrics"],

  "properties": {

    "run_id": {
      "type": "integer"
    },

    "metrics": {

      "type": "array",

      "items": {

        "type": "object",

        "required": ["name", "value"],

        "properties": {

          "name": {
            "type": "string"
          },

          "value": {
            "type": "number"
          },

          "unit": {
            "type": "string"
          },

          "mode": {
            "type": "string",
            "enum": ["trail", "robot", "patrol"]
          },

          "description": {
            "type": "string"
          }
        }
      }
    }
  }
}